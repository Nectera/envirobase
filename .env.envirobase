# ─────────────────────────────────────────────
# EnviroBase Tenant Configuration
# Copy these env vars into your Vercel project
# ─────────────────────────────────────────────

# Branding
NEXT_PUBLIC_APP_NAME=EnviroBase
NEXT_PUBLIC_COMPANY_NAME=EnviroBase
NEXT_PUBLIC_COMPANY_SHORT=EnviroBase
NEXT_PUBLIC_BRAND_COLOR=#2D5A42
NEXT_PUBLIC_SUPPORT_EMAIL=info@envirobase.io
NEXT_PUBLIC_COMPANY_LOCATION=Denver, CO
NEXT_PUBLIC_APP_DOMAIN=envirobase.io

# Logo (path relative to /public)
NEXT_PUBLIC_LOGO_URL=/envirobase-logo.png
NEXT_PUBLIC_ICON_192=/icons/envirobase-192x192.png
NEXT_PUBLIC_ICON_512=/icons/envirobase-512x512.png

# Auth & App URL (set to your Vercel deployment URL)
NEXTAUTH_URL=https://app.envirobase.io
NEXTAUTH_SECRET=  # generate with: openssl rand -base64 32

# Database (separate Supabase project per tenant)
DATABASE_URL=  # postgres://...@db.xxx.supabase.co:5432/postgres

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@envirobase.io
SMTP_FROM_NAME=EnviroBase

# AI (Anthropic)
ANTHROPIC_API_KEY=

# RingCentral (optional - for SMS features)
# RC_CLIENT_ID=
# RC_CLIENT_SECRET=

# QuickBooks (optional)
# QB_CLIENT_ID=
# QB_CLIENT_SECRET=

# Cron job secret
CRON_SECRET=  # generate with: openssl rand -base64 32
