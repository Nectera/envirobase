# ===========================
# NextAuth Configuration
# ===========================
# Secret key for NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# URL where the application is deployed (required in production)
NEXTAUTH_URL=http://localhost:3000

# ===========================
# Database (Supabase PostgreSQL)
# ===========================
# Connection string from Supabase: Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ===========================
# AI & Anthropic Integration
# ===========================
# Anthropic API key for Claude AI features
# Leave empty to disable AI features (they will gracefully degrade)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ===========================
# Google Maps & Places
# ===========================
# Google Places API key for address autocomplete and location services
# Leave empty to disable address autocomplete features
# Get your key from: https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=AIzaSy-your-api-key-here
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSy-your-api-key-here

# ===========================
# Email (SMTP) Configuration
# ===========================
# Leave all SMTP fields empty to disable email features
# Using Gmail/Google Workspace? Generate an App Password: https://myaccount.google.com/apppasswords

# SMTP server hostname (e.g., smtp.gmail.com for Gmail)
SMTP_HOST=smtp.gmail.com

# SMTP server port (typically 587 for TLS or 465 for SSL)
SMTP_PORT=587

# Email account username (usually your email address)
SMTP_USER=your-email@example.com

# Email account password (or App Password for Gmail)
SMTP_PASSWORD=your-app-password-here

# Display name for outgoing emails
SMTP_FROM_NAME=Your Company Name

# ===========================
# QuickBooks Online Integration
# ===========================
# Leave empty to disable QuickBooks sync features
# Get credentials from: https://developer.intuit.com/

# OAuth Client ID from Intuit Developer Portal
QUICKBOOKS_CLIENT_ID=your-client-id-here

# OAuth Client Secret from Intuit Developer Portal
QUICKBOOKS_CLIENT_SECRET=your-client-secret-here

# OAuth redirect URI (must match configured value in Intuit Portal)
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback

# Environment: "sandbox" or "production"
QUICKBOOKS_ENVIRONMENT=sandbox

# ===========================
# RingCentral Integration
# ===========================
# Leave empty to disable RingCentral phone features
# Get credentials from: https://developer.ringcentral.com/

# OAuth Client ID from RingCentral Developer Portal
RINGCENTRAL_CLIENT_ID=your-client-id-here

# OAuth Client Secret from RingCentral Developer Portal
RINGCENTRAL_CLIENT_SECRET=your-client-secret-here

# OAuth redirect URI (must match configured value in RingCentral Portal)
RINGCENTRAL_REDIRECT_URI=http://localhost:3000/api/ringcentral/callback

# RingCentral API server URL
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com

# ===========================
# PandaDoc Integration
# ===========================
# Leave empty to disable PandaDoc document generation features
# Get your API key from: https://app.pandadoc.com/settings/api/

PANDADOC_API_KEY=your-api-key-here

# ===========================
# Gusto Payroll Integration
# ===========================
# Leave empty to disable Gusto payroll features
# Get credentials from: https://developer.gusto.com/

# OAuth Client ID from Gusto Developer Portal
GUSTO_CLIENT_ID=your-client-id-here

# OAuth Client Secret from Gusto Developer Portal
GUSTO_CLIENT_SECRET=your-client-secret-here

# OAuth redirect URI (must match configured value in Gusto Portal)
GUSTO_REDIRECT_URI=http://localhost:3000/api/gusto/callback

# Environment: "demo" or "production"
GUSTO_ENVIRONMENT=demo
