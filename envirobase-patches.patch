Date: Thu, 19 Mar 2026 08:52:44 -0600
Subject: [PATCH 1/3] fix: tighten gap between sidebar and main content

Reduced main content left margin from 264px to 248px (104px to 88px
collapsed) so the content sits closer to the floating sidebar.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 src/components/AuthenticatedShell.tsx | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/components/AuthenticatedShell.tsx b/src/components/AuthenticatedShell.tsx
index b2d3e9d..8a6a655 100644
--- a/src/components/AuthenticatedShell.tsx
+++ b/src/components/AuthenticatedShell.tsx
@@ -42,7 +42,7 @@ function ShellContent({
         {/* Main content — offset for floating sidebar on desktop */}
         <div
           className={`flex-1 flex flex-col overflow-hidden min-w-0 transition-all duration-300 ease-in-out ${
-            collapsed ? "md:ml-[104px]" : "md:ml-[264px]"
+            collapsed ? "md:ml-[88px]" : "md:ml-[248px]"
           }`}
         >
           {/* Demo Read-Only Banner */}
-- 
2.34.1


